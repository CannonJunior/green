{
  "name": "green",
  "version": "0.1.0",
  "description": "Personal AI assistant — iMessage control plane for Claude Code projects",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts --channel signal",
    "dev:local": "tsx src/index.ts --channel local",
    "dev:gateway": "tsx src/index.ts --channel gateway",
    "start": "node dist/index.js --channel signal",
    "start:local": "node dist/index.js --channel local",
    "start:gateway": "node dist/index.js --channel gateway",
    "dashboard": "tsx dashboard/cli.ts",
    "dashboard:web": "tsx src/dashboard.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "best": "file:../best",
    "bets": "file:../bets",
    "trip": "file:../trip",
    "chew": "file:../chew/green",
    "log": "file:../log",
    "js-yaml": "^4.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
