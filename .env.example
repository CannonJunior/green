# Copy this to .env and fill in your values.
# Green reads these at startup.

# Required: Anthropic API key for the Green agent
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the config.yml path
# GREEN_CONFIG=./config.yml

# Optional: free Alpha Vantage key for /alpha structured scoring and earnings calendar
# Get yours at https://www.alphavantage.co/support/#api-key (free, no credit card)
# Without this key /alpha falls back to AI-only analysis via web search.
ALPHA_VANTAGE_API_KEY=
